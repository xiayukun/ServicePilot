<Window x:Class="ServicePilot.Views.TemplateManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage templates" Height="540" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E">
    <Window.Resources>
        <Style x:Key="DarkGridColumnHeader" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#FF2A2A3C"/>
            <Setter Property="Foreground" Value="#EEFFFFFF"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style x:Key="DarkGridCell" TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EEFFFFFF"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF2F78A8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkGridRow" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="#222A2A3C"/>
            <Setter Property="Foreground" Value="#EEFFFFFF"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#182A2A3C"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF2F78A8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>
        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <Button x:Name="AddButton" Content="Add" Width="76" Height="28" Margin="0,0,6,0" Click="Add_Click"/>
            <Button x:Name="EditButton" Content="Edit" Width="76" Height="28" Margin="0,0,6,0" Click="Edit_Click"/>
            <Button x:Name="DeleteButton" Content="Delete" Width="76" Height="28" Margin="0,0,6,0" Click="Delete_Click"/>
            <Button x:Name="ExportButton" Content="Export" Width="76" Height="28" Margin="0,0,6,0" Click="Export_Click"/>
            <Button x:Name="ImportButton" Content="Import" Width="76" Height="28" Margin="0,0,6,0" Click="Import_Click"/>
        </WrapPanel>

        <DataGrid x:Name="TemplatesGrid" Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  AlternationCount="2"
                  Background="#FF252536"
                  Foreground="#EEFFFFFF"
                  RowBackground="#222A2A3C"
                  AlternatingRowBackground="#182A2A3C"
                  BorderBrush="#55FFFFFF"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#22FFFFFF"
                  ColumnHeaderStyle="{StaticResource DarkGridColumnHeader}"
                  RowStyle="{StaticResource DarkGridRow}"
                  CellStyle="{StaticResource DarkGridCell}"
                  SelectionChanged="TemplatesGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="NameColumn" Header="Name" Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn x:Name="DescriptionColumn" Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn x:Name="StepsColumn" Header="Actions" Binding="{Binding ScriptSteps.Count}" Width="80"/>
                <DataGridTextColumn x:Name="UpdatedAtColumn" Header="Updated" Binding="{Binding UpdatedAt}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBox x:Name="PreviewBox" Grid.Row="2" Margin="0,8,0,0"
                 IsReadOnly="True" AcceptsReturn="True"
                 FontFamily="Consolas" FontSize="12"
                 Background="#221E1E2E" Foreground="#DDDDDD" BorderBrush="#55FFFFFF"
                 VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
