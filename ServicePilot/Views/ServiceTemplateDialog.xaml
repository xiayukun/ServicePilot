<Window x:Class="ServicePilot.Views.ServiceTemplateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="模板" Height="680" Width="1040"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock x:Name="TemplateNameLabel" Text="模板名称" Foreground="#DDFFFFFF" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Height="30" Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="DescriptionLabel" Text="说明" Foreground="#DDFFFFFF" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionBox" Height="30" Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock x:Name="ScriptStepsLabel" Text="脚本步骤" Foreground="#DDFFFFFF" FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="+" Width="28" Height="24" Margin="2,0" Click="AddStep_Click"/>
                        <Button Content="↑" Width="28" Height="24" Margin="2,0" Click="MoveUp_Click"/>
                        <Button Content="↓" Width="28" Height="24" Margin="2,0" Click="MoveDown_Click"/>
                        <Button x:Name="DeleteStepButton" Content="删" Width="38" Height="24" Margin="2,0" Click="DeleteStep_Click"/>
                    </StackPanel>
                </DockPanel>
                <ListBox x:Name="StepsList" Grid.Row="1" Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"
                         SelectionChanged="StepsList_SelectionChanged" DisplayMemberPath="DisplayLabel"/>
                <StackPanel Grid.Row="2" Margin="0,12,0,6">
                    <TextBlock x:Name="VariablesTitleText" Text="预设变量" Foreground="#DDFFFFFF" FontSize="12"/>
                    <TextBlock x:Name="VariablesHelpText" Text="一行一个启动变量" Foreground="#88FFFFFF" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBox x:Name="VariablesBox" Grid.Row="3" AcceptsReturn="True"
                         Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
            </Grid>

            <Border Grid.Column="1" Background="#33FFFFFF" CornerRadius="6" Padding="12">
                <Grid x:Name="StepEditor" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock x:Name="StepNameLabel" Text="步骤名称" Foreground="#BBFFFFFF" FontSize="11"/>
                            <TextBox x:Name="StepNameBox" Width="220" Height="28" Background="#22FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock x:Name="ScriptTypeLabel" Text="脚本类型" Foreground="#BBFFFFFF" FontSize="11"/>
                            <ComboBox x:Name="ScriptTypeCombo" Width="130" Height="28">
                                <ComboBoxItem Content="Batch"/>
                                <ComboBoxItem Content="PowerShell"/>
                                <ComboBoxItem Content="Python"/>
                                <ComboBoxItem Content="Node.js"/>
                            </ComboBox>
                        </StackPanel>
                        <CheckBox x:Name="UseVariableCheck"
                                  Content="使用变量"
                                  IsChecked="True"
                                  Foreground="#BBFFFFFF"
                                  VerticalAlignment="Bottom"
                                  Margin="12,0,0,3"/>
                        <CheckBox x:Name="RunOnStartCheck"
                                  Content="启动执行"
                                  IsChecked="True"
                                  Foreground="#BBFFFFFF"
                                  VerticalAlignment="Bottom"
                                  Margin="12,0,0,3"
                                  Checked="RunOnStartCheck_Changed"
                                  Unchecked="RunOnStartCheck_Changed"/>
                        <CheckBox x:Name="OpenLogOnRunCheck"
                                  Content="弹出日志"
                                  Foreground="#BBFFFFFF"
                                  VerticalAlignment="Bottom"
                                  Margin="12,0,0,3"/>
                    </WrapPanel>
                    <TextBlock x:Name="ScriptContentLabel" Grid.Row="1" Text="脚本内容" Foreground="#BBFFFFFF" FontSize="11" Margin="0,0,0,4"/>
                    <avalonedit:TextEditor x:Name="ScriptEditor" Grid.Row="2"
                                           FontFamily="Consolas" FontSize="13"
                                           ShowLineNumbers="True"
                                           Background="#FF1E1E2E"
                                           Foreground="#DDDDDDDD"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelButton" Content="取消" Width="80" Height="32" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button x:Name="SaveButton" Content="保存" Width="80" Height="32" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
