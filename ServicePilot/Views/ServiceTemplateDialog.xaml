<Window x:Class="ServicePilot.Views.ServiceTemplateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:converters="clr-namespace:ServicePilot.Converters"
        Title="Template" Height="700" Width="1080"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E">
    <Window.Resources>
        <converters:StepKindDisplayConverter x:Key="StepKindDisplay"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock x:Name="TemplateNameLabel" Text="Template name" Foreground="#DDFFFFFF" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Height="30" Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="DescriptionLabel" Text="Description" Foreground="#DDFFFFFF" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionBox" Height="30" Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock x:Name="ScriptStepsLabel" Text="Actions" Foreground="#DDFFFFFF" FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="+" Width="28" Height="24" Margin="2,0" Click="AddStep_Click"/>
                        <Button Content="Up" Width="34" Height="24" Margin="2,0" Click="MoveUp_Click"/>
                        <Button Content="Dn" Width="34" Height="24" Margin="2,0" Click="MoveDown_Click"/>
                        <Button x:Name="DeleteStepButton" Content="Del" Width="38" Height="24" Margin="2,0" Click="DeleteStep_Click"/>
                    </StackPanel>
                </DockPanel>
                <ListBox x:Name="StepsList" Grid.Row="1" Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"
                         SelectionChanged="StepsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayLabel}" Foreground="#EEFFFFFF"/>
                                <TextBlock Foreground="#77FFFFFF">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat=" ({0})">
                                            <Binding Path="Kind" Converter="{StaticResource StepKindDisplay}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="2" Margin="0,12,0,6">
                    <TextBlock x:Name="VariablesTitleText" Text="Action variables" Foreground="#DDFFFFFF" FontSize="12"/>
                    <TextBlock x:Name="VariablesHelpText" Text="One variable per line" Foreground="#88FFFFFF" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBox x:Name="VariablesBox" Grid.Row="3" AcceptsReturn="True" TextWrapping="NoWrap"
                         Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
            </Grid>

            <Border Grid.Column="1" Background="#33FFFFFF" CornerRadius="6" Padding="12">
                <Grid x:Name="StepEditor" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock x:Name="StepNameLabel" Text="Name" Foreground="#BBFFFFFF" FontSize="11"/>
                            <TextBox x:Name="StepNameBox" Width="220" Height="28" Background="#22FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock x:Name="StepKindLabel" Text="Kind" Foreground="#BBFFFFFF" FontSize="11"/>
                            <ComboBox x:Name="StepKindCombo" Width="130" Height="28" SelectionChanged="StepKindCombo_SelectionChanged">
                                <ComboBoxItem Content="Action"/>
                                <ComboBoxItem Content="Composite"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel x:Name="ScriptTypePanel" Margin="0,0,10,0">
                            <TextBlock x:Name="ScriptTypeLabel" Text="Script type" Foreground="#BBFFFFFF" FontSize="11"/>
                            <ComboBox x:Name="ScriptTypeCombo" Width="130" Height="28">
                                <ComboBoxItem Content="Batch"/>
                                <ComboBoxItem Content="PowerShell"/>
                                <ComboBoxItem Content="Python"/>
                                <ComboBoxItem Content="Node.js"/>
                            </ComboBox>
                        </StackPanel>
                        <CheckBox x:Name="UseVariableCheck"
                                  Content="Use variable"
                                  IsChecked="True"
                                  Foreground="#BBFFFFFF"
                                  VerticalAlignment="Bottom"
                                  Margin="12,0,0,3"/>
                        <CheckBox x:Name="OpenLogOnRunCheck"
                                  Content="Open log"
                                  Foreground="#BBFFFFFF"
                                  VerticalAlignment="Bottom"
                                  Margin="12,0,0,3"/>
                    </WrapPanel>
                    <Grid x:Name="CompositeMembersPanel" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="120"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,4">
                            <TextBlock x:Name="MembersLabel" Text="Members" Foreground="#BBFFFFFF" FontSize="11" VerticalAlignment="Center"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <ComboBox x:Name="MemberCandidateCombo" Width="240" Height="26" DisplayMemberPath="Name" Margin="0,0,4,0"/>
                                <Button x:Name="AddMemberButton" Content="Add" Width="52" Height="26" Margin="0,0,4,0" Click="AddMember_Click"/>
                                <Button x:Name="RemoveMemberButton" Content="Remove" Width="62" Height="26" Margin="0,0,4,0" Click="RemoveMember_Click"/>
                                <Button Content="Up" Width="34" Height="26" Margin="0,0,4,0" Click="MoveMemberUp_Click"/>
                                <Button Content="Dn" Width="34" Height="26" Click="MoveMemberDown_Click"/>
                            </StackPanel>
                        </DockPanel>
                        <ListBox x:Name="MembersList" Grid.Row="1"
                                 Background="#22FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"
                                 DisplayMemberPath="Name"/>
                    </Grid>
                    <TextBlock x:Name="ScriptContentLabel" Grid.Row="2" Text="Script content" Foreground="#BBFFFFFF" FontSize="11" Margin="0,0,0,4"/>
                    <avalonedit:TextEditor x:Name="ScriptEditor" Grid.Row="3"
                                           FontFamily="Consolas" FontSize="13"
                                           ShowLineNumbers="True"
                                           Background="#FF1E1E2E"
                                           Foreground="#DDDDDDDD"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="32" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button x:Name="SaveButton" Content="Save" Width="80" Height="32" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
