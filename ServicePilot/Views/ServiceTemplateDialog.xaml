<ui:FluentWindow x:Class="ServicePilot.Views.ServiceTemplateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:converters="clr-namespace:ServicePilot.Converters"
        Title="Template" Height="700" Width="1400"
        WindowStartupLocation="CenterOwner" Background="#FF1E1E2E"
        Icon="pack://application:,,,/Resources/Icons/app.ico"
        ExtendsContentIntoTitleBar="True">
    <Window.Resources>
        <converters:StepKindDisplayConverter x:Key="StepKindDisplay"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="Template"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Resources/Icons/app.png" Width="18" Height="18" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock x:Name="TemplateNameLabel" Text="Template name" FontSize="12" Margin="0,0,0,4"/>
                    <ui:TextBox x:Name="NameBox" Height="34" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="DescriptionLabel" Text="Description" FontSize="12" Margin="0,0,0,4"/>
                    <ui:TextBox x:Name="DescriptionBox" Height="34" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock x:Name="ScriptStepsLabel" Text="Actions" FontSize="12" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <ui:Button Content="+" Width="32" Height="30" Margin="2,0" Click="AddStep_Click"/>
                            <ui:Button Content="Up" Width="46" Height="30" Margin="2,0" Click="MoveUp_Click"/>
                            <ui:Button Content="Dn" Width="46" Height="30" Margin="2,0" Click="MoveDown_Click"/>
                            <ui:Button x:Name="DeleteStepButton" Content="Del" Width="46" Height="30" Margin="2,0" Click="DeleteStep_Click"/>
                        </StackPanel>
                    </DockPanel>
                    <ListBox x:Name="StepsList" Grid.Row="1"
                             SelectionChanged="StepsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayLabel}"/>
                                    <TextBlock>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat=" ({0})">
                                                <Binding Path="Kind" Converter="{StaticResource StepKindDisplay}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Margin="0,12,0,6">
                        <TextBlock x:Name="VariablesTitleText" Text="Action variables" FontSize="12"/>
                        <TextBlock x:Name="VariablesHelpText" Text="One variable per line" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ui:TextBox x:Name="VariablesBox" Grid.Row="3" AcceptsReturn="True" TextWrapping="NoWrap" VerticalContentAlignment="Top"/>
                </Grid>

                <Border Grid.Column="1" CornerRadius="6" Padding="12">
                    <Grid x:Name="StepEditor" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock x:Name="StepNameLabel" Text="Name" FontSize="11"/>
                                <ui:TextBox x:Name="StepNameBox" Width="180" Height="34" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock x:Name="StepKindLabel" Text="Kind" FontSize="11"/>
                                <ComboBox x:Name="StepKindCombo" Width="110" Height="34" SelectionChanged="StepKindCombo_SelectionChanged">
                                    <ComboBoxItem Content="Action"/>
                                    <ComboBoxItem Content="Composite"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel x:Name="ScriptTypePanel" Margin="0,0,10,0">
                                <TextBlock x:Name="ScriptTypeLabel" Text="Script type" FontSize="11"/>
                                <ComboBox x:Name="ScriptTypeCombo" Width="110" Height="34">
                                    <ComboBoxItem Content="Batch"/>
                                    <ComboBoxItem Content="PowerShell"/>
                                    <ComboBoxItem Content="Python"/>
                                    <ComboBoxItem Content="Node.js"/>
                                </ComboBox>
                            </StackPanel>
                            <CheckBox x:Name="UseVariableCheck"
                                      Content="Use variable"
                                      IsChecked="True"
                                      VerticalAlignment="Bottom"
                                      Margin="12,0,0,3"/>
                            <CheckBox x:Name="OpenLogOnRunCheck"
                                      Content="Open log"
                                      VerticalAlignment="Bottom"
                                      Margin="12,0,0,3"/>
                        </WrapPanel>
                        <Grid x:Name="CompositeMembersPanel" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="120"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                                <TextBlock x:Name="MembersLabel" Text="Members" FontSize="11" VerticalAlignment="Center"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <ComboBox x:Name="MemberCandidateCombo" Width="240" Height="34" DisplayMemberPath="Name" Margin="0,0,4,0"/>
                                    <ui:Button x:Name="AddMemberButton" Content="Add" Width="52" Height="26" Margin="0,0,4,0" Click="AddMember_Click"/>
                                    <ui:Button x:Name="RemoveMemberButton" Content="Remove" Width="62" Height="26" Margin="0,0,4,0" Click="RemoveMember_Click"/>
                                    <ui:Button Content="Up" Width="34" Height="26" Margin="0,0,4,0" Click="MoveMemberUp_Click"/>
                                    <ui:Button Content="Dn" Width="34" Height="26" Click="MoveMemberDown_Click"/>
                                </StackPanel>
                            </DockPanel>
                            <ListBox x:Name="MembersList" Grid.Row="1"
                                     DisplayMemberPath="Name"/>
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="ScriptContentLabel" Text="Script content" FontSize="11" />
                            <TextBlock Grid.Column="1" Text="Log merge function" FontSize="11" Margin="12,0,0,0" />
                        </Grid>
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <avalonedit:TextEditor Grid.Column="0" x:Name="ScriptEditor"
                                                   FontFamily="Consolas" FontSize="13"
                                                   ShowLineNumbers="True"
                                                   Background="#FF1E1E2E"
                                                   Foreground="#FFD4D4D4"/>
                            <Border Grid.Column="1" CornerRadius="6" Padding="12" Margin="12,0,0,0">
                                <Grid x:Name="MergeScriptPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" x:Name="MergeFunctionLabel" Text="Merge function" FontSize="11" Margin="0,0,0,4"/>
                                    <avalonedit:TextEditor Grid.Row="1" x:Name="MergeScriptEditor"
                                                           FontFamily="Consolas" FontSize="13"
                                                           ShowLineNumbers="True"
                                                           Background="#FF1E1E2E"
                                                           Foreground="#FFD4D4D4"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <ui:Button x:Name="CancelButton" Content="Cancel" Width="80" Height="32" Margin="0,0,8,0" Click="Cancel_Click"/>
                <ui:Button x:Name="SaveButton" Content="Save" Width="80" Height="32" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
