<Window x:Class="ServicePilot.Views.TemplateSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="应用模板" Height="360" Width="540"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E2E">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="TemplatesList" Grid.Row="0"
                 Background="#33FFFFFF" BorderBrush="#55FFFFFF"
                 Foreground="#EEFFFFFF"
                 MouseDoubleClick="TemplatesList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding Template.Name}" FontWeight="SemiBold" Foreground="#EEFFFFFF"/>
                        <TextBlock Text="{Binding Template.Description}" Foreground="#99FFFFFF" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding Summary}" Foreground="#77FFFFFF"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelButton" Content="取消" Width="76" Height="30" Margin="0,0,8,0"
                    Background="#44FFFFFF" Foreground="#DDFFFFFF" BorderBrush="#55FFFFFF"
                    Click="Cancel_Click"/>
            <Button x:Name="ApplyButton" Content="应用" Width="76" Height="30"
                    Background="#445A8DEE" Foreground="#EEFFFFFF" BorderBrush="#555A8DEE"
                    Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</Window>
