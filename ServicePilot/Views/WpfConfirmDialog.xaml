<ui:FluentWindow x:Class="ServicePilot.Views.WpfConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ServicePilot" Height="200" Width="420"
        WindowStartupLocation="CenterOwner" Background="#FF1E1E2E"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="ServicePilot"
                     ShowMaximize="False"
                     ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="MessageText" TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       FontSize="14"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,12,0,0">
                <ui:Button x:Name="YesButton" Content="是" Width="80" Height="32"
                           Margin="0,0,8,0" Appearance="Primary" Click="Yes_Click"/>
                <ui:Button x:Name="NoButton" Content="否" Width="80" Height="32"
                           Click="No_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
