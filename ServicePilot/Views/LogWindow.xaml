<ui:FluentWindow x:Class="ServicePilot.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:converters="clr-namespace:ServicePilot.Converters"
        Title="日志" Height="560" Width="1040"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/Icons/app.ico"
        ExtendsContentIntoTitleBar="True">

    <Window.Resources>
        <converters:LogLevelColorConverter x:Key="LogLevelColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- WPF-UI TitleBar: provides min/max/close + drag. Title binds to the window Title so the header
             shows the full "日志 - <服务名>" text (no separate toolbar title needed). -->
        <ui:TitleBar Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Resources/Icons/app.png" Width="18" Height="18" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 工具栏：标题已移到头部标题栏，这里只放操作按钮，整体靠右。 -->
            <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="True">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RunActionButton" Content="运行动作" Width="82" Height="32" VerticalAlignment="Center"
                            Margin="0,0,6,0" Click="RunAction_Click"/>
                    <ui:Button x:Name="StopButton" Content="停止" Width="56" Height="32" VerticalAlignment="Center"
                            Margin="0,0,10,0" Appearance="Danger" Click="Stop_Click"/>
                    <ui:TextBox x:Name="SearchBox" Width="150" Height="34" VerticalAlignment="Center" VerticalContentAlignment="Center"
                             PlaceholderText="搜索日志"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown"
                             Margin="0,0,4,0"/>
                    <ui:Button x:Name="FindPreviousButton" Content="上一个" Width="72" Height="32" VerticalAlignment="Center"
                            Margin="0,0,4,0" Click="FindPrevious_Click"/>
                    <ui:Button x:Name="FindNextButton" Content="下一个" Width="72" Height="32" VerticalAlignment="Center"
                            Margin="0,0,4,0" Click="FindNext_Click"/>
                    <TextBlock x:Name="SearchStatusText" Width="42"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <CheckBox x:Name="AutoScrollCheck" Content="自动滚动" IsChecked="True"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:Button x:Name="SummaryButton" Content="摘要" Width="58" Height="32" VerticalAlignment="Center"
                            Margin="0,0,6,0" Click="Summary_Click"
                            ToolTip="折叠全部合并组，只看摘要一行；再次点击展开全部"/>
                    <ui:Button x:Name="EditButton" Content="编辑" Width="58" Height="32" VerticalAlignment="Center"
                            Margin="0,0,6,0" Click="Edit_Click"/>
                    <ui:Button x:Name="ClearButton" Content="清空" Width="58" Height="32" VerticalAlignment="Center" Click="Clear_Click"/>
                </StackPanel>
            </DockPanel>

            <TabControl x:Name="LogTabs" Grid.Row="1"
                                Height="30"
                                DisplayMemberPath="Header"
                                Background="Transparent"
                        SelectionChanged="LogTabs_SelectionChanged"
                        Margin="0,0,0,6"/>

            <!-- 日志查看器 + 右侧概览 minimap -->
            <Grid Grid.Row="2" Background="#FF1E1E2E">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <avalonedit:TextEditor x:Name="LogEditor" Grid.Column="0"
                                       FontFamily="Consolas" FontSize="12"
                                       ShowLineNumbers="False"
                                       IsReadOnly="True"
                                       Background="#FF1E1E2E"
                                       Foreground="#FFD4D4D4"
                                       WordWrap="False"
                                       Padding="0,0,0,14"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto"
                                       PreviewKeyDown="LogEditor_PreviewKeyDown">
                    <avalonedit:TextEditor.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="CopySelectedMenuItem" Header="复制选中" Click="CopySelected_Click"/>
                            <MenuItem x:Name="CopyAllMenuItem" Header="复制全部" Click="CopyAll_Click"/>
                        </ContextMenu>
                    </avalonedit:TextEditor.ContextMenu>
                </avalonedit:TextEditor>
                <Border x:Name="OverviewHost" Grid.Column="1" Width="12"/>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
