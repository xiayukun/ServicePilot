<Window x:Class="ServicePilot.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:converters="clr-namespace:ServicePilot.Converters"
        Title="日志" Height="560" Width="1040"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E">

    <Window.Resources>
        <converters:LogLevelColorConverter x:Key="LogLevelColor"/>
        <Style x:Key="LogActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#EEFFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#FF111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="TitleText" Text="日志" Foreground="#EEFFFFFF"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       MaxWidth="260"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                <Button x:Name="RunActionButton" Content="运行动作" Width="82" Height="26"
                        Style="{StaticResource LogActionButtonStyle}"
                        Background="#3359C9FF"
                        BorderBrush="#5559C9FF"
                        Click="RunAction_Click"
                        Margin="0,0,6,0"/>
                <Button x:Name="StopButton" Content="停止" Width="48" Height="26"
                        Style="{StaticResource LogActionButtonStyle}"
                        Background="#33FF6B6B"
                        BorderBrush="#55FF6B6B"
                        Click="Stop_Click"
                        Margin="0,0,10,0"/>
                <TextBox x:Name="SearchBox" Width="150" Height="26"
                         ToolTip="搜索日志"
                         Background="#22FFFFFF"
                         Foreground="#EEFFFFFF"
                         BorderBrush="#55FFFFFF"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"
                         Margin="0,0,4,0"/>
                <Button x:Name="FindPreviousButton" Content="上" Width="44" Height="26"
                        Style="{StaticResource LogActionButtonStyle}"
                        Background="#44FFFFFF"
                        BorderBrush="#55FFFFFF"
                        Click="FindPrevious_Click"
                        Margin="0,0,4,0"/>
                <Button x:Name="FindNextButton" Content="下" Width="44" Height="26"
                        Style="{StaticResource LogActionButtonStyle}"
                        Background="#44FFFFFF"
                        BorderBrush="#55FFFFFF"
                        Click="FindNext_Click"
                        Margin="0,0,4,0"/>
                <TextBlock x:Name="SearchStatusText" Width="42"
                           Foreground="#99FFFFFF"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <CheckBox x:Name="AutoScrollCheck" Content="自动滚动" IsChecked="True"
                          Foreground="#BBFFFFFF" FontSize="12"
                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button x:Name="EditButton" Content="编辑" Width="58" Height="26"
                        Style="{StaticResource LogActionButtonStyle}"
                        Background="#44FFFFFF"
                        BorderBrush="#55FFFFFF"
                        Click="Edit_Click"
                        Margin="0,0,6,0"/>
                <Button x:Name="ClearButton" Content="清空" Width="58" Height="26"
                        Style="{StaticResource LogActionButtonStyle}"
                        Background="#44FFFFFF"
                        BorderBrush="#55FFFFFF"
                        Click="Clear_Click"/>
            </StackPanel>
        </DockPanel>

        <TabControl x:Name="LogTabs" Grid.Row="1"
                    Height="30"
                    Background="Transparent"
                    BorderBrush="#33FFFFFF"
                    Foreground="#EEFFFFFF"
                    SelectionChanged="LogTabs_SelectionChanged"
                    Margin="0,0,0,6">
            <TabControl.Resources>
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Setter Property="Foreground" Value="#DDFFFFFF"/>
                    <Setter Property="Background" Value="#22222F"/>
                    <Setter Property="BorderBrush" Value="#44FFFFFF"/>
                    <Setter Property="Padding" Value="10,4"/>
                    <Setter Property="MinWidth" Value="72"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabItem}">
                                <Border x:Name="TabBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        Padding="{TemplateBinding Padding}"
                                        Margin="0,0,2,0"
                                        CornerRadius="2,2,0,0">
                                    <ContentPresenter x:Name="ContentSite"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="False"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#2A2D44"/>
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#6688B8FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#333854"/>
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#7797C7FF"/>
                                        <Setter Property="Panel.ZIndex" Value="1"/>
                                        <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#77FFFFFF"/>
                                        <Setter TargetName="TabBorder" Property="Background" Value="#191927"/>
                                        <Setter TargetName="TabBorder" Property="BorderBrush" Value="#22FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#333854"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Header}" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
        </TabControl>

        <!-- 日志查看器 -->
        <avalonedit:TextEditor x:Name="LogEditor" Grid.Row="2"
                               FontFamily="Consolas" FontSize="12"
                               ShowLineNumbers="False"
                               IsReadOnly="True"
                               WordWrap="False"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"
                               Background="#33FFFFFF"
                               Foreground="#EEFFFFFF"
                               PreviewKeyDown="LogEditor_PreviewKeyDown">
            <avalonedit:TextEditor.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="CopySelectedMenuItem" Header="复制选中" Click="CopySelected_Click"/>
                    <MenuItem x:Name="CopyAllMenuItem" Header="复制全部" Click="CopyAll_Click"/>
                </ContextMenu>
            </avalonedit:TextEditor.ContextMenu>
        </avalonedit:TextEditor>
    </Grid>
</Window>
