<Window x:Class="ServicePilot.Views.ServiceConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="服务配置" Height="700" Width="1040"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock x:Name="ServiceNameLabel" Text="服务名称" Foreground="#DDFFFFFF" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Height="30" Padding="6,4"
                         Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="WorkingDirectoryLabel" Text="工作目录" Foreground="#DDFFFFFF" FontSize="12" Margin="0,0,0,4"/>
                <DockPanel>
                    <Button x:Name="BrowseButton" DockPanel.Dock="Right" Content="浏览" Width="72" Height="30"
                            Margin="6,0,0,0" Click="Browse_Click"
                            Background="#44FFFFFF" Foreground="#DDFFFFFF" BorderBrush="#55FFFFFF"/>
                    <TextBox x:Name="DirBox" Height="30" Padding="6,4"
                             Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
                </DockPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="170"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock x:Name="ScriptStepsLabel" Text="脚本步骤" Foreground="#DDFFFFFF" FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="ApplyTemplateButton" Content="应用模板" Width="88" Height="24" Margin="2,0" Click="ApplyTemplate_Click"/>
                        <Button Content="+" Width="28" Height="24" Margin="2,0" Click="AddStep_Click"/>
                        <Button Content="↑" Width="28" Height="24" Margin="2,0" Click="MoveUp_Click"/>
                        <Button Content="↓" Width="28" Height="24" Margin="2,0" Click="MoveDown_Click"/>
                        <Button x:Name="DeleteStepButton" Content="删" Width="38" Height="24" Margin="2,0" Click="DeleteStep_Click"/>
                    </StackPanel>
                </DockPanel>

                <ListBox x:Name="StepsList" Grid.Row="1"
                         Background="#33FFFFFF" BorderBrush="#55FFFFFF" Foreground="#EEFFFFFF"
                         SelectionChanged="StepsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayLabel}" Foreground="#EEFFFFFF"/>
                                <TextBlock Text="{Binding ScriptType, StringFormat= ({0})}" Foreground="#77FFFFFF"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="0,12,0,6">
                    <TextBlock x:Name="VariablesTitleText" Text="预设变量" Foreground="#DDFFFFFF" FontSize="12"/>
                    <TextBlock x:Name="VariablesHelpText" Text="一行一个变量" Foreground="#88FFFFFF" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <TextBox x:Name="VariablesBox" Grid.Row="3"
                         AcceptsReturn="True" TextWrapping="NoWrap"
                         Background="#33FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"
                         ToolTip="每行一个字符串。启动、重启或执行步骤时可选择一个变量；它会注入为 SERVICEPILOT_VARIABLE，并替换脚本中的 {{variable}} / {{变量}}。"/>
            </Grid>

            <Border Grid.Column="1" Background="#33FFFFFF" CornerRadius="6" Padding="12">
                <Grid x:Name="StepEditor" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock x:Name="StepNameLabel" Text="步骤名称" Foreground="#BBFFFFFF" FontSize="11"/>
                            <TextBox x:Name="StepNameBox" Width="220" Height="28" Margin="0,2,0,0"
                                     Background="#22FFFFFF" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock x:Name="ScriptTypeLabel" Text="脚本类型" Foreground="#BBFFFFFF" FontSize="11"/>
                            <ComboBox x:Name="ScriptTypeCombo" Width="130" Height="28" Margin="0,2,0,0">
                                <ComboBoxItem Content="Batch"/>
                                <ComboBoxItem Content="PowerShell"/>
                                <ComboBoxItem Content="Python"/>
                                <ComboBoxItem Content="Node.js"/>
                            </ComboBox>
                        </StackPanel>
                        <CheckBox x:Name="UseVariableCheck"
                                  Content="使用变量"
                                  IsChecked="True"
                                  Foreground="#BBFFFFFF"
                                  VerticalAlignment="Bottom"
                                  Margin="12,0,0,5"/>
                        <CheckBox x:Name="RunOnStartCheck"
                                  Content="启动执行"
                                  IsChecked="True"
                                  Foreground="#BBFFFFFF"
                                  VerticalAlignment="Bottom"
                                  Margin="12,0,0,5"
                                  Checked="RunOnStartCheck_Changed"
                                  Unchecked="RunOnStartCheck_Changed"/>
                        <CheckBox x:Name="OpenLogOnRunCheck"
                                  Content="弹出日志"
                                  Foreground="#BBFFFFFF"
                                  VerticalAlignment="Bottom"
                                  Margin="12,0,0,5"/>
                    </WrapPanel>

                    <TextBlock x:Name="ScriptContentLabel" Grid.Row="1" Text="脚本内容" Foreground="#BBFFFFFF" FontSize="11" Margin="0,0,0,4"/>
                    <avalonedit:TextEditor x:Name="ScriptEditor" Grid.Row="2"
                                           FontFamily="Consolas" FontSize="13"
                                           ShowLineNumbers="True"
                                           Background="#FF1E1E2E"
                                           Foreground="#DDDDDDDD"/>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <CheckBox x:Name="AutoStartCheck" Content="启动 ServicePilot 时自动启动此服务"
                      Foreground="#BBFFFFFF" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SaveTemplateButton" Content="存为模板" Width="86" Height="34" Margin="0,0,8,0"
                        Background="#44FFFFFF" Foreground="#DDFFFFFF" BorderBrush="#55FFFFFF"
                        Click="SaveTemplate_Click"/>
                <Button x:Name="CancelButton" Content="取消" Width="80" Height="34" Margin="0,0,8,0"
                        Background="#44FFFFFF" Foreground="#DDFFFFFF" BorderBrush="#55FFFFFF"
                        Click="Cancel_Click"/>
                <Button x:Name="SaveButton" Content="保存" Width="80" Height="34"
                        Background="#444CAF50" Foreground="#EEFFFFFF" BorderBrush="#554CAF50"
                        Click="Save_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
