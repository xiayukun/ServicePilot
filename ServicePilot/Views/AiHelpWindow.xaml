<Window x:Class="ServicePilot.Views.AiHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Copy ServicePilot help for AI" Height="620" Width="860"
        MinHeight="520" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="IntroText" Grid.Row="0"
                   Foreground="#EEFFFFFF"
                   TextWrapping="Wrap"
                   FontSize="14"
                   Margin="0,0,0,10"/>

        <TextBox x:Name="PromptBox" Grid.Row="1"
                 IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True"
                 TextWrapping="Wrap"
                 Background="#221E1E2E" Foreground="#EEFFFFFF" BorderBrush="#55FFFFFF"
                 FontFamily="Consolas" FontSize="13"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CopyAllButton" Width="96" Height="30" Margin="0,0,8,0" Click="CopyAll_Click"/>
            <Button x:Name="CopyCommandsButton" Width="104" Height="30" Margin="0,0,8,0" Click="CopyCommands_Click"/>
            <Button x:Name="CloseButton" Width="82" Height="30" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
